---
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container">
    <p class="colophon">
      Set in <strong>Fraunces</strong> &amp; <strong>IBM Plex Sans / Mono</strong>.
      Compiled in Astro. Distributed under <a href={`${base}/contributing/`}>CC BY-SA 4.0</a> unless otherwise noted.
      Treat compliance content as illustrative — verify with a qualified subject-matter expert.
    </p>
    <p class="meta">
      Edition 1.0 &nbsp; · &nbsp; {year}<br/>
      <a href={`${base}/contributing/`} class="no-link">Contribute</a>
    </p>
  </div>
</footer>
