---
import { TRACKS, TRACK_ORDER, type TrackId } from '../lib/tracks';

interface Props {
  currentTrack?: TrackId | null;
  currentPath?: string;
}

const { currentTrack = null, currentPath = '' } = Astro.props;
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
const isActive = (path: string) => currentPath === path || currentPath.startsWith(path + '/');
---

<header class="site-nav">
  <div class="container">
    <a class="brand" href={`${base}/`} aria-label="The DevOps Field Manual — home">
      <span class="brand-mark">DOFM</span>
      <span class="brand-name"><span class="brand-prefix">The DevOps </span><em>Field Manual</em></span>
    </a>

    <nav class="nav-links" aria-label="Primary">
      <div class="track-tabs nav-aux" aria-label="Tracks">
        {TRACK_ORDER.map((id) => (
          <a
            href={`${base}/${id}/`}
            data-track-active={currentTrack === id ? 'true' : 'false'}
            title={TRACKS[id].tagline}
          >
            {TRACKS[id].short}
          </a>
        ))}
      </div>

      <a href={`${base}/glossary/`} class:list={['nav-text-link', isActive(`${base}/glossary`) && 'active']}>Glossary</a>
      <a href={`${base}/maturity/`} class:list={['nav-text-link', isActive(`${base}/maturity`) && 'active']}>Maturity</a>
      <a href={`${base}/choose-your-track/`} class:list={['nav-text-link nav-aux', isActive(`${base}/choose-your-track`) && 'active']}>Choose track</a>

      <button class="nav-search-btn" type="button" id="open-search" aria-label="Search the manual" title="Search (press / or Ctrl/Cmd+K)">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <circle cx="7" cy="7" r="5" />
          <line x1="11" y1="11" x2="14" y2="14" />
        </svg>
        <span class="nav-search-label">Search</span>
        <kbd class="nav-search-kbd" aria-hidden="true">/</kbd>
      </button>
      <button class="icon-btn" type="button" id="theme-toggle" aria-label="Toggle theme" aria-pressed="false" title="Switch theme">
        <svg class="theme-icon-light" width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <circle cx="8" cy="8" r="3" />
          <line x1="8" y1="1" x2="8" y2="3"/>
          <line x1="8" y1="13" x2="8" y2="15"/>
          <line x1="1" y1="8" x2="3" y2="8"/>
          <line x1="13" y1="8" x2="15" y2="8"/>
          <line x1="3" y1="3" x2="4.5" y2="4.5"/>
          <line x1="11.5" y1="11.5" x2="13" y2="13"/>
          <line x1="13" y1="3" x2="11.5" y2="4.5"/>
          <line x1="4.5" y1="11.5" x2="3" y2="13"/>
        </svg>
        <svg class="theme-icon-dark" width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5" style="display:none" aria-hidden="true">
          <path d="M14 9.5A6 6 0 0 1 6.5 2 6 6 0 1 0 14 9.5z"/>
        </svg>
      </button>
      <a href="https://github.com/" class="icon-btn nav-gh" rel="me" aria-label="GitHub repository" id="gh-link">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="currentColor">
          <path d="M8 0C3.58 0 0 3.58 0 8a8 8 0 0 0 5.47 7.59c.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8z"/>
        </svg>
      </a>

      <button class="icon-btn menu-toggle" type="button" id="menu-toggle" aria-label="Open menu" aria-controls="mobile-drawer" aria-expanded="false">
        <svg width="14" height="14" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="1.5">
          <line x1="2" y1="4" x2="14" y2="4"/>
          <line x1="2" y1="8" x2="14" y2="8"/>
          <line x1="2" y1="12" x2="14" y2="12"/>
        </svg>
      </button>
    </nav>
  </div>
</header>
