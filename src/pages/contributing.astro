---
import { getEntry, render } from 'astro:content';
import PageLayout from '../layouts/PageLayout.astro';

const entry = await getEntry('shared', 'contributing');
if (!entry) throw new Error('shared/contributing entry not found');
const { Content } = await render(entry);
---

<PageLayout title="Contributing" description={entry.data.summary} variant="prose" eyebrow="Meta">
  <header slot="header">
    <h1 class="contrib-h1">{entry.data.title}</h1>
    <p class="contrib-summary">{entry.data.summary}</p>
  </header>
  <div class="prose contrib-prose">
    <Content />
  </div>
</PageLayout>

<style>
  .contrib-h1 { font-size: var(--fs-h1); margin-block: var(--sp-3); }
  .contrib-summary {
    font-size: var(--fs-lead);
    color: var(--ink-2);
    font-style: italic;
    border-bottom: 1px solid var(--rule);
    padding-bottom: var(--sp-5);
    margin-bottom: var(--sp-5);
  }
  .contrib-prose { max-width: var(--measure); }
</style>
