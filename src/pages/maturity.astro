---
import { getEntry, render } from 'astro:content';
import PageLayout from '../layouts/PageLayout.astro';

const entry = await getEntry('shared', 'maturity');
if (!entry) throw new Error('shared/maturity entry not found');
const { Content } = await render(entry);
---

<PageLayout title="Maturity model" description={entry.data.summary} variant="wide" eyebrow="Assessment">
  <header slot="header" class="m-header container">
    <h1>{entry.data.title}</h1>
    <p class="m-summary">{entry.data.summary}</p>
  </header>

  <div class="container m-content">
    <div class="prose m-prose">
      <Content />
    </div>
  </div>
</PageLayout>

<style is:global>
  .m-header { padding-block: var(--sp-3) var(--sp-6); max-width: 60rem; }
  .m-header h1 { font-size: var(--fs-h1); margin-block: var(--sp-3) var(--sp-3); }
  .m-summary { font-size: var(--fs-lead); color: var(--ink-2); font-style: italic; }

  .m-content { padding-bottom: var(--sp-9); }
  .m-prose { max-width: 64rem; }
  .m-prose h2 { font-size: var(--fs-h2); margin-top: var(--sp-7); }

  /* Heatmap-style maturity matrix table — when there are 6 columns (Domain + 5 levels) */
  .m-prose table {
    table-layout: fixed;
    font-size: 0.78rem;
    line-height: 1.4;
  }
  .m-prose table tbody td {
    font-family: var(--font-body);
    font-size: 0.78rem;
    padding: 0.7rem 0.7rem;
    transition: background 120ms ease;
  }
  .m-prose table tbody tr td:nth-child(2) { background: color-mix(in srgb, var(--accent-soft) 30%, transparent); }
  .m-prose table tbody tr td:nth-child(3) { background: color-mix(in srgb, var(--accent-soft) 50%, transparent); }
  .m-prose table tbody tr td:nth-child(4) { background: color-mix(in srgb, var(--accent-soft) 70%, transparent); }
  .m-prose table tbody tr td:nth-child(5) { background: color-mix(in srgb, var(--accent-soft) 85%, transparent); }
  .m-prose table tbody tr td:nth-child(6) { background: color-mix(in srgb, var(--accent) 35%, var(--paper)); }
  .m-prose table tbody tr th {
    font-family: var(--font-display);
    font-size: 0.95rem;
    font-weight: 500;
    text-transform: none;
    letter-spacing: 0;
    color: var(--ink);
    padding-right: 1rem;
    width: 13rem;
  }
  .m-prose table thead th {
    text-align: left;
    background: transparent;
  }
  .m-prose table thead th:nth-child(1) { width: 13rem; }

  @media (max-width: 800px) {
    .m-prose table { font-size: 0.7rem; }
    .m-prose table tbody th { width: 8rem; font-size: 0.78rem; }
    .m-prose table tbody td { font-size: 0.7rem; padding: 0.5rem 0.45rem; }
  }
</style>
